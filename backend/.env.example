APP_ENV=local
APP_HTTP_ADDR=:8080
APP_API_BASE_PATH=/api/v1
APP_MIGRATIONS_DIR=./migrations
APP_ACCESS_TOKEN_TTL=15m
APP_REFRESH_TOKEN_TTL=24h
APP_REFRESH_COOKIE_NAME=refresh_token
APP_REFRESH_COOKIE_PATH=/api/v1/auth
APP_REFRESH_COOKIE_DOMAIN=
APP_REFRESH_COOKIE_SECURE=false
APP_JWT_SECRET=change-me
APP_JWT_ISSUER=contapp
APP_JWT_AUDIENCE=contapp-api
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DATABASE_URL=postgres://app_user:pwd1@localhost:5432/conta_db?sslmode=disable
