          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('ticketing tasks returns 200', function () { pm.response.to.have.status(200); });"] } }]
        },
        {
          "name": "User Logout",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{user_access_token}}", "type": "string" }] },
            "method": "POST",
            "header": [],
