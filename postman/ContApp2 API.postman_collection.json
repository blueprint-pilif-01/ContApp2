          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('contract templates returns 200', function () { pm.response.to.have.status(200); });",
            "pm.test('seed template exists', function () { pm.expect(pm.response.json().contract_templates).to.be.an('array').that.is.not.empty; });"
          ] } }]
        },
