          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('clients returns 200', function () { pm.response.to.have.status(200); });",
            "pm.test('seed clients exist', function () { pm.expect(pm.response.json().clients).to.be.an('array').that.is.not.empty; });"
          ] } }]
        },
